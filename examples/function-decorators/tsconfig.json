{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "plugins": [
      { "name": "fntypescript" },
      { "transform": "./src/plugin.ts", "import": "transformer" }
    ]
  },
  "include": ["src"]
}
