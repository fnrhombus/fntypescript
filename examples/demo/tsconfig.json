{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "noEmit": true,
    "plugins": [{
      "name": "fntypescript",
      "plugins": [
        "@fntypescript/plugin-function-decorators",
        "@fntypescript/plugin-sql-diagnostics",
        "@fntypescript/plugin-styled-completions",
        "@fntypescript/plugin-enhanced-hover",
        "@fntypescript/plugin-custom-definitions",
        "@fntypescript/plugin-graphql-diagnostics"
      ]
    }]
  },
  "include": ["src"]
}
