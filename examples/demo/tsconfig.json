{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "plugins": [{ "name": "fntypescript" }]
  },
  "include": ["src"]
}
